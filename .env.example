# ---- DrugPipe Environment Variables ----
# Copy this file to .env and fill in your values.

# OriGene (optional, for Stage 1 target discovery)
ORIGENE_SERVER_URL=http://127.0.0.1:8788
ORIGENE_LLM_API_KEY=

# ChEMBL API (Stage 2, usually no key needed)
CHEMBL_BASE_URL=https://www.ebi.ac.uk/chembl/api/data

# REINVENT4 (optional, for Stage 3 H2L)
REINVENT4_PATH=
REINVENT4_PRIOR_PATH=
