# ---- DrugPipe Environment Variables ----
# Copy this file to .env and fill in your values.

# OriGene (optional, for Stage 1 target discovery)
ORIGENE_SERVER_URL=http://127.0.0.1:8788
ORIGENE_LLM_API_KEY=

# ChEMBL API (Stage 2, usually no key needed)
CHEMBL_BASE_URL=https://www.ebi.ac.uk/chembl/api/data

# REINVENT4 (optional, for Stage 3 H2L)
# NOTE: Effective overrides must use DP_ prefix.
# These two legacy keys are kept for backward compatibility/reference only.
REINVENT4_PATH=
REINVENT4_PRIOR_PATH=
DP_HIT_TO_LEAD__REINVENT4__REINVENT_PATH=/root/miniconda3/envs/t2lead/bin/reinvent
DP_HIT_TO_LEAD__REINVENT4__PRIOR_PATH=/root/REINVENT4/priors/reinvent.prior
