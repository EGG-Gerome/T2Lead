# ---- DrugPipe / T2Lead environment ----
# `make install` copies this to .env (if missing) and appends DP_* paths for REINVENT4 + CReM.

# ChEMBL API (Stage 2 — usually no key needed)
CHEMBL_BASE_URL=https://www.ebi.ac.uk/chembl/api/data

# Legacy keys (reference only; effective overrides use DP_ — filled by make install)
REINVENT4_PATH=
REINVENT4_PRIOR_PATH=
